menu "Pin Configuration"
    menu "SPI Pins"
        # SPI pin mapping is only configurable on the ESP32-S3
        visible if IDF_TARGET_ESP32S3
        config SPI_MISO
            int "MISO pin"
            default 7
        config SPI_MOSI
            int "MOSI pin"
            default 18 
        config SPI_CLOCK
            int "Clock pin"
            default 47 
    endmenu

    menu "TFT Pins"
        config TFT_CS_PIN
            int "Chip Select pin"
            default 3

        config TFT_RESET_PIN
            int "Reset pin"
            default 48 
    
        config TFT_DC_PIN
            int "Data/Command pin"
            default 8

        config TFT_BACKLIGHT_PIN
            int "Backlight pin"
            default -1
    endmenu
endmenu

choice DISPLAY_COLOR_MODE
    bool "Color Mode"
    default DISPLAY_COLOR_MODE_BGR
    config DISPLAY_COLOR_MODE_BGR
        bool "Blue,Green,Red"
    config DISPLAY_COLOR_MODE_RGB
        bool "Red,Green,Blue"
endchoice

config DISPLAY_COLOR_MODE
    int
    default 1 if DISPLAY_COLOR_MODE_BGR
    default 0 if DISPLAY_COLOR_MODE_RGB

config LV_HOR_RES_MAX
    int "Horizontal resolution"
    default 320

config LV_VER_RES_MAX
    int "Vertical resolution"
    default 480


config SPI_TFT_CLOCK_SPEED_HZ
    int "SPI clock speed (Hz)"
    default 40000000

config DISPLAY_SPI_QUEUE_LEN
    int "SPI queue length"
    default 50

config SPI_MAX_TRANSFER_SIZE
    int "Maximum SPI transfer size"
    default 4000
