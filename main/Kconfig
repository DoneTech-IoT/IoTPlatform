menu "Done Main Config"    

    choice DONE_BOARDS
        prompt "Select your development board"
        #default DONE_BOARDS_LILYGO_S3
        help
            Select predefined board
            
        config DONE_BOARDS_LILYGO_S3
            bool "LILYGO-S3 Display board"                  

        config DONE_BOARDS_WROOM
            bool "Wroom-S3 board"                                        
    endchoice        
         
    config DONE_PARTITION_TABLE_CUSTOM
        bool "Done's Custom partition table CSV"  
        depends on PARTITION_TABLE_CUSTOM     
        default y 

    config DONE_PARTITION_TABLE_CUSTOM_FILENAME           
        string "Done's custom partition table"
        depends on DONE_PARTITION_TABLE_CUSTOM                 
        default "partitions_s3_8g.csv"  if DONE_BOARDS_WROOM
        #default "partitions_s3_16g.csv" if DONE_BOARDS_LILYGO_S3                
        help
            Name of the custom partition CSV filename. This path is evaluated
            relative to the project root directory.        
                        
endmenu